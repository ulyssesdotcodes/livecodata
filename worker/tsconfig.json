{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    // Workers globals (WebSocketPair, DurableObject, ExportedHandler, …) —
    // deliberately no "dom" here, since Workers' Request/Response/WebSocket
    // shapes aren't quite the browser's, and the two libs conflict if mixed.
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["**/*.ts"]
}
